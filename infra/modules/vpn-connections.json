      }
    },
    {
      "type": "Microsoft.Network/localNetworkGateways",
      "apiVersion": "2023-11-01",
      "name": "[variables('onPremLocalGatewayName')]",
      "location": "[parameters('location')]",
      "properties": {
        "localNetworkAddressSpace": {
          "addressPrefixes": [
            "[parameters('hubAddressPrefix')]"
          ]
        },
        "gatewayIpAddress": "[reference(resourceId('Microsoft.Network/publicIPAddresses', 'pip-vpngw-hub-demo'), '2023-11-01').ipAddress]"
      }
    },
    {
      "type": "Microsoft.Network/connections",
      "apiVersion": "2023-11-01",
      "name": "conn-hub-to-onprem",
      "location": "[parameters('location')]",
      "properties": {
        "connectionType": "IPsec",
        "virtualNetworkGateway1": {
          "id": "[parameters('hubVpnGatewayId')]"
        },
        "localNetworkGateway2": {
          "id": "[resourceId('Microsoft.Network/localNetworkGateways', variables('hubLocalGatewayName'))]"
        },
        "sharedKey": "[variables('sharedKey')]",
        "connectionProtocol": "IKEv2",
        "enableBgp": false,
        "usePolicyBasedTrafficSelectors": false,
        "ipsecPolicies": []
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/localNetworkGateways', variables('hubLocalGatewayName'))]"
      ]
    },
    {
      "type": "Microsoft.Network/connections",
      "apiVersion": "2023-11-01",
      "name": "conn-onprem-to-hub",
      "location": "[parameters('location')]",
      "properties": {
        "connectionType": "IPsec",
        "virtualNetworkGateway1": {
          "id": "[parameters('onPremVpnGatewayId')]"
        },
        "localNetworkGateway2": {
          "id": "[resourceId('Microsoft.Network/localNetworkGateways', variables('onPremLocalGatewayName'))]"
        },
        "sharedKey": "[variables('sharedKey')]",
        "connectionProtocol": "IKEv2",
        "enableBgp": false,
        "usePolicyBasedTrafficSelectors": false,
        "ipsecPolicies": []
      },
      "dependsOn": [
